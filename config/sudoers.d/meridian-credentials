# /etc/sudoers.d/meridian-credentials
# Install with: sudo install -m 0440 -o root -g root \
#   meridian-credentials /etc/sudoers.d/meridian-credentials
#
# Lets the portal invoke the credential-rotation wrapper. The wrapper
# reads every secret from stdin, not argv, so the sudoers entry below
# doesn't leak anything either. Target argument is one of a closed set
# of string literals; see scripts/rotate-credential.sh for the dispatch
# table.

meridian ALL=(root) NOPASSWD: \
    /opt/meridian/scripts/rotate-credential.sh linux\:meridian-user, \
    /opt/meridian/scripts/rotate-credential.sh linux\:root, \
    /opt/meridian/scripts/rotate-credential.sh db\:meridian, \
    /opt/meridian/scripts/rotate-credential.sh key\:row_hmac, \
    /opt/meridian/scripts/rotate-credential.sh key\:master, \
    /opt/meridian/scripts/rotate-credential.sh ssh\:host_keys
