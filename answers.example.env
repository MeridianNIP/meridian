# Meridian NIP unattended-install answers.
#
# Copy this file to `answers.local.env` (or any name you like) and edit
# every value to match your environment. Pass the path to install.sh
# via `--config`:
#
#     sudo ./install.sh --unattended --config /opt/meridian/answers.local.env
#
# Every line here is consumed by install.sh's prompt() helper — a value
# present in this file silently fills the prompt instead of asking.
# Lines you leave blank get the install.sh default OR the interactive
# prompt if the value can't be defaulted.

PORTAL_NAME="Meridian NIP"
# FQDN the portal answers on. install.sh uses this for the TLS cert SAN,
# the nginx server_name, and the audit/login email "from" if you don't
# override email_from_address later.
PORTAL_DOMAIN="meridiannip.example.com"

ADMIN_USERNAME="admin"
ADMIN_EMAIL="ops@example.com"
# Leave ADMIN_TEMP_PASSWORD blank to use the install.sh default
# ("password"). The portal forces a change at first login + MFA enroll.
ADMIN_TEMP_PASSWORD=""

DB_NAME="meridian"
DB_USER="meridian"
# Leave DB_PASSWORD blank to let install.sh generate a strong random one
# and write it to /etc/meridian/meridian.conf.
DB_PASSWORD=""

TIMEZONE="UTC"

# SSL method on first install:
#   - "self-signed"  — install.sh generates a self-signed cert (good for labs)
#   - "letsencrypt"  — provisions a real cert via certbot (needs public DNS)
#   - "cloudflare"   — same but with the Cloudflare DNS-01 plugin (needs token)
#   - "none"         — HTTP only (NOT recommended; admin login goes plaintext)
SSL_METHOD="self-signed"

# Scope-of-use enforcement:
#   - "internal" — block tools from targeting public/RFC1918-external IPs
#   - "external" — block tools from targeting RFC1918/private IPs
#   - "both"     — no restriction (typical for labs and ops teams)
SCOPE_OF_USE="both"

# SSH port; blank keeps the default 22.
SSH_PORT=""

# Encrypt /var/lib/meridian + /etc/meridian with LUKS at install time?
# Blank or "n" = no. "y" = walks you through the passphrase prompt.
LUKS_ENCRYPT="n"

# --- Static LAN networking --------------------------------------------------
# Leave STATIC_IP blank to keep whatever DHCP assigned. If you set it,
# install.sh writes /etc/systemd/network/10-meridian.network with these
# values; the change takes effect on next reboot (won't kill this SSH
# session mid-install).
#
# Format: <ip>/<prefix>   e.g. 192.168.50.240/24
STATIC_IP=""
STATIC_GATEWAY=""
STATIC_DNS=""

# --- Admin allowlist (fail2ban) --------------------------------------------
# CIDR that the fail2ban [DEFAULT] ignoreip will skip. Set to the subnet
# your admin/deploy workstations live on so a typo-storm doesn't lock
# you out. Leave blank for "no allowlist beyond loopback".
ADMIN_CIDR=""
